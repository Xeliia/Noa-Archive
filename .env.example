# === LLM Backend Configuration ===
# For Ollama (laptop with MX350):
LLM_BACKEND_URL=http://localhost:11434/v1
LLM_MODEL=llama3

# For llama.cpp (PC with RX580):
# LLM_BACKEND_URL=http://localhost:8080/v1
# LLM_MODEL=your-model-name

# === API Security ===
# Change this to a secure random string!
API_KEY=your-secret-key-here

# === Server Settings ===
HOST=0.0.0.0
PORT=8000

# === Frontend URL (for CORS) ===
FRONTEND_URL=http://localhost:5173

# === System Prompt ===
SYSTEM_PROMPT=You are a helpful, warm AI assistant named Ushio Noa. Keep responses concise and conversational.
