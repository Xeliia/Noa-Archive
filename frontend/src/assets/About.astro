---
import { UserRound, Code2, Zap, BookOpen } from "lucide-astro";
import { Image } from "astro:assets";
import Img1 from "../assets/mini-profile-1.png";
import Img2 from "../assets/mini-profile-2.png";
---

<section class="about-section">
    <div class="about-header" data-aos="fade-down">
        <div class="icon-container">
            <UserRound class="icon-header" />
        </div>
        <h2 class="section-title">About Me</h2>
        <p class="intro-text">
            Hi! I'm Axel Aaron G. Arceleta, a 3rd year student at the
            Technological University of the Philippines. I like playing with new
            technology, and I'm building my path towards DevOps, Backend, and
            Cloud Engineering.
        </p>
        <div class="info-divider">
            <span
                >Here are some information or facts about me that I don't bother
                sharing.</span
            >
        </div>
    </div>

    <div class="content-grid">
        <div class="profile-card" data-aos="fade-right" data-aos-delay="100">
            <div class="profile-image-wrapper" id="profileWrapper">
                <div class="flipper">
                    <Image
                        src={Img1}
                        alt="Profile Front"
                        class="profile-face profile-front"
                        id="profileImageFront"
                    />

                    <Image
                        src={Img2}
                        alt="Profile Back"
                        class="profile-face profile-back"
                        id="profileImageBack"
                    />
                </div>
            </div>
            <div class="quick-facts">
                <div class="fact-item">
                    <span class="fact-label">Birthday</span>
                    <span class="fact-value">07/29</span>
                </div>
                <div class="fact-item">
                    <span class="fact-label">Location</span>
                    <span class="fact-value">Laguna, PH</span>
                </div>
                <div class="fact-item">
                    <span class="fact-label">University</span>
                    <span class="fact-value"
                        >Technological University of the Philippines</span
                    >
                </div>
                <div class="fact-item">
                    <span class="fact-label">Degree</span>
                    <span class="fact-value"
                        >Bachelor of Science in Computer Science</span
                    >
                </div>
            </div>
        </div>

        <div class="info-sections">
            <div
                class="info-card glass-card-dark"
                data-aos="fade-left"
                data-aos-delay="200"
            >
                <div class="card-header">
                    <Zap size={24} class="card-icon" />
                    <h3>My Passion</h3>
                </div>
                <p class="card-text">
                    I'm very passionate about backend systems, cloud platforms,
                    and automation. I'm a Linux enthusiast, who uses Arch btw. I
                    am also deeply interested in data engineering and data
                    analysis.
                </p>
            </div>

            <div
                class="info-card glass-card-dark"
                data-aos="fade-left"
                data-aos-delay="300"
            >
                <div class="card-header">
                    <Code2 size={24} class="card-icon" />
                    <h3>Career Focus</h3>
                </div>
                <p class="card-text">
                    I am considering DevOps, and networking for my career in the
                    future. Currently I'm pursuing my Bachelors of Science in
                    Computer Science degree, with interests in backend
                    development and cloud engineering.
                </p>
            </div>

            <div
                class="info-card glass-card-dark"
                data-aos="fade-left"
                data-aos-delay="400"
            >
                <div class="card-header">
                    <BookOpen size={24} class="card-icon" />
                    <h3>In My Free Time</h3>
                </div>
                <p class="card-text">
                    I spend my free time learning new tools, building small
                    projects, and exploring tech forums. I also like to draw
                    anime style art for my pastime, and gaming.
                </p>
            </div>

            <div
                class="hobbies-section"
                data-aos="fade-up"
                data-aos-delay="500"
            >
                <h4 class="pills-title">Interests & Hobbies</h4>
                <div class="pills-container">
                    <span class="pill">Drawing</span>
                    <span class="pill">Cycling</span>
                    <span class="pill">Gaming</span>
                    <span class="pill">Linux</span>
                    <span class="pill">DevOps</span>
                    <span class="pill">Cloud Engineering</span>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .about-section {
        max-width: 1200px;
        margin: 0 auto;
        padding: 4rem 2rem;
        position: relative;
    }

    /* Header Section */
    .about-header {
        display: flex;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        gap: 1rem;
        padding: 0.5rem 0;
    }

    .icon-container {
        display: flex;
        justify-content: center;
    }

    .icon-header {
        width: 5rem;
        height: 5rem;
        border-radius: 45%;
        color: #5e81ac;
        box-shadow: 0 6px 18px #8fbcbb;
        transition: all 0.3s;
    }

    .icon-header:hover {
        box-shadow: 0 6px 50px #5e81ac;
        transform: scale(1.1);
    }

    .section-title {
        font-size: 3.5rem;
        font-weight: 600;
    }

    .intro-text {
        display: block;
        max-width: 100ch;
        margin: 0.75rem auto;
        text-align: justify;
        text-indent: 6ch;
        line-height: 1.6;
        font-weight: 600;
        overflow-wrap: anywhere;
        hyphens: auto;
        font-size: 1rem;
        font-weight: 600;
        color: #4c566a;
    }

    .info-divider {
        display: block;
        max-width: 100ch;
        padding-bottom: 2rem;
        margin: 0.75rem auto;
        text-align: center;
        line-height: 1.6;
        font-weight: 600;
        overflow-wrap: anywhere;
        hyphens: auto;
        font-size: 1rem;
        font-weight: 600;
        color: #4c566a;
    }

    .content-grid {
        display: grid;
        grid-template-columns: 1fr 2fr;
        gap: 3rem;
        align-items: start;
    }

    .profile-card {
        display: flex;
        flex-direction: column;
        gap: 2rem;
        position: sticky;
        top: 2rem;
        padding-top: 3rem;
    }

    .profile-image-wrapper {
        width: 100%;
        aspect-ratio: 1;
        border-radius: 50%;
        overflow: hidden;
        background: transparent;
        padding: 4px;
        box-shadow: 0 8px 32px rgba(136, 192, 208, 0.2);
        cursor: pointer;
        perspective: 1000px;
    }

    .profile-image-wrapper:hover {
        box-shadow: 0 12px 40px rgba(136, 192, 208, 0.4);
    }

    .flipper {
        position: relative;
        width: 100%;
        height: 100%;

        transition: transform 0.6s;
        transform-style: preserve-3d;
    }

    .profile-face {
        position: absolute;
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 50%;
        display: block;
        backface-visibility: hidden;
    }

    .profile-back {
        transform: rotateY(180deg);
    }

    .profile-image-wrapper.flipped .flipper {
        transform: rotateY(180deg);
    }

    .quick-facts {
        display: grid;
        grid-template-columns: 1fr 1fr;
        padding-top: 2.5rem;
        gap: 1rem;
    }

    .fact-item {
        background: #2e3440;
        backdrop-filter: blur(12px);
        border: 1px solid rgba(136, 192, 208, 0.2);
        border-radius: 12px;
        box-shadow: #5e81ac 0px 4px 12px;
        padding: 1.2rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .fact-label {
        font-size: 0.85rem;
        color: #eceff4;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .fact-value {
        font-size: 1rem;
        color: #88c0d0;
        font-weight: 700;
    }

    .info-sections {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .info-card {
        padding: 2rem;
        border-radius: 16px;
        animation: fadeInUp 0.8s ease-out;
    }

    .info-card:nth-child(1) {
        animation-delay: 0.1s;
        box-shadow: 0 1px 50px -12px #bf616a;
    }

    .info-card:nth-child(2) {
        animation-delay: 0.2s;
        box-shadow: 0 1px 50px -12px #d08770;
    }

    .info-card:nth-child(3) {
        animation-delay: 0.3s;
        box-shadow: 0 1px 50px -12px #ebcb8b;
    }

    .card-header {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1rem;
    }

    .card-icon {
        flex-shrink: 0;
    }

    .info-card:nth-child(1) .card-icon {
        color: #bf616a;
    }

    .info-card:nth-child(2) .card-icon {
        color: #d08770;
    }

    .info-card:nth-child(3) .card-icon {
        color: #ebcb8b;
    }

    .card-header h3 {
        font-size: 1.3rem;
        margin: 0;
        font-weight: 700;
        color: #3b4252;
    }

    .card-text {
        margin: 0;
        line-height: 1.7;
        color: #2e3440;
        font-size: 1rem;
        text-align: justify;
    }

    .hobbies-section {
        margin-top: 1rem;
    }

    .pills-title {
        font-size: 1.1rem;
        font-weight: 700;
        margin: 0 0 1rem;
    }

    .pills-container {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
    }

    .pill {
        background: #2e3440;
        border: 2px solid #3b4252;
        color: #88c0d0;
        padding: 0.6rem 1.2rem;
        border-radius: 50px;
        font-size: 0.95rem;
        font-weight: 600;
        transition: all 0.3s ease;
        cursor: default;
    }

    .pill:nth-child(5n + 1) {
        box-shadow: 0 2px 6px #bf616a;
    }

    .pill:nth-child(5n + 2) {
        box-shadow: 0 2px 6px #d08770;
    }

    .pill:nth-child(5n + 3) {
        box-shadow: 0 2px 6px #ebcb8b;
    }

    .pill:nth-child(5n + 4) {
        box-shadow: 0 2px 6px #a3be8c;
    }

    .pill:nth-child(5n + 5) {
        box-shadow: 0 2px 6px #b48ead;
    }

    .pill:hover {
        background: #d8dee9;
        color: #2e3440;
        border-color: #8fbcbb;
        box-shadow: 0 0 20px rgba(136, 192, 208, 0.2);
    }

    .pill:nth-child(5n + 1):hover {
        box-shadow: 0 4px 10px #b48ead;
    }

    .pill:nth-child(5n + 2):hover {
        box-shadow: 0 4px 10px #a3be8c;
    }

    .pill:nth-child(5n + 3):hover {
        box-shadow: 0 4px 10px #ebcb8b;
    }

    .pill:nth-child(5n + 4):hover {
        box-shadow: 0 4px 10px #d08770;
    }

    .pill:nth-child(5n + 5):hover {
        box-shadow: 0 4px 10px #bf616a;
    }

    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @media (max-width: 1024px) {
        .about-section {
            padding: 3rem 1.5rem;
        }

        .section-title {
            font-size: 3rem;
        }

        .content-grid {
            grid-template-columns: 1fr 1.5fr;
            gap: 2rem;
        }

        .profile-image-wrapper {
            max-width: 280px;
            margin: 0 auto;
        }
    }

    @media (max-width: 768px) {
        .about-section {
            padding: 2rem 1rem;
        }

        .section-title {
            font-size: 2.5rem;
        }

        .intro-text {
            text-indent: 3ch;
            font-size: 0.95rem;
        }

        .content-grid {
            grid-template-columns: 1fr;
            gap: 2rem;
        }

        .profile-card {
            position: relative;
            top: 0;
        }

        .profile-image-wrapper {
            max-width: 220px;
            margin: 0 auto;
        }

        .quick-facts {
            grid-template-columns: 1fr 1fr;
        }

        .fact-item {
            padding: 1rem;
        }

        .fact-label {
            font-size: 0.75rem;
        }

        .fact-value {
            font-size: 0.9rem;
        }

        .info-card {
            padding: 1.5rem;
        }

        .card-header h3 {
            font-size: 1.1rem;
        }

        .card-text {
            font-size: 0.9rem;
        }

        .pills-container {
            gap: 0.5rem;
            justify-content: center;
        }

        .pill {
            padding: 0.5rem 1rem;
            font-size: 0.85rem;
        }
    }

    @media (max-width: 480px) {
        .about-section {
            padding: 1.5rem 0.75rem;
        }

        .section-title {
            font-size: 2rem;
        }

        .icon-header {
            width: 4rem;
            height: 4rem;
        }

        .intro-text,
        .info-divider {
            font-size: 0.9rem;
        }

        .quick-facts {
            grid-template-columns: 1fr;
            gap: 0.75rem;
        }

        .profile-image-wrapper {
            max-width: 180px;
        }

        .info-card {
            padding: 1.25rem;
        }

        .pill {
            padding: 0.4rem 0.8rem;
            font-size: 0.8rem;
        }
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const profileWrapper = document.getElementById("profileWrapper");

        if (!profileWrapper) return;

        profileWrapper.addEventListener("click", () => {
            profileWrapper.classList.toggle("flipped");
        });
    });
</script>
